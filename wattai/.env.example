# Database
DB_USER=wattai
DB_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+asyncpg://wattai:change_me_strong_password@postgres:5432/wattai

# Redis
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:change_me_redis_password@redis:6379/0

# MQTT
MQTT_HOST=mosquitto
MQTT_PORT=8883
MQTT_INTERNAL_USER=ingestion_service
MQTT_INTERNAL_PASSWORD=change_me_mqtt_password
MQTT_CA_PATH=/etc/letsencrypt/live/mqtt.yourdomain.com/chain.pem

# API
SECRET_KEY=change_me_64_char_random_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Admin — default subscription pricing (overridable via admin_config table)
DEFAULT_PREMIUM_PRICE_USD=9.99

# Domain
DOMAIN=yourdomain.com
CORS_ORIGINS=["https://app.yourdomain.com"]
